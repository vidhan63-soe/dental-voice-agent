# ===========================================================================
# Bright Smile Dental — Voice AI Agent
# ===========================================================================

# Public HTTPS URL Twilio hits for webhooks (use ngrok for local dev)
PUBLIC_BASE_URL=https://voice.yourdomain.com

# ---- Twilio ----
# From https://console.twilio.com/ — Account Info panel
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# A voice-enabled Twilio phone number you own (E.164)
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Comma-separated list of numbers verified in Twilio Console → Verified Caller IDs.
# Trial accounts can only call verified numbers.
# Leave empty once you upgrade to a paid account.
SANDBOX_NUMBERS=+15551234567,+919876543210

# Number that receives escalated calls via <Dial>
RECEPTIONIST_PHONE=+1XXXXXXXXXX

# ---- Sarvam AI (STT + TTS) ----
# Get your key at https://dashboard.sarvam.ai
SARVAM_API_KEY=sk_xxx
SARVAM_STT_MODEL=saarika:v2.5
SARVAM_STT_LANG=en-IN
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_SPEAKER=anushka
SARVAM_TTS_LANG=en-IN

# ---- Google Gemini (fallback LLM) ----
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.0-flash-lite

# ---- Groq (primary LLM for the agent conversation loop) ----
# Get your key at https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=openai/gpt-oss-120b

# ---- OpenRouter (fallback if Groq key not set) ----
# Get your key at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free

# ---- Anthropic Claude (optional, for additional LLM support) ----
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-haiku-4-5

# ---- Scheduling ----
# Clinic timezone (see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
CLINIC_TZ=Asia/Kolkata
CLINIC_OPEN_HOUR=9          # inclusive
CLINIC_CLOSE_HOUR=19        # exclusive (last slot starts at 18:00)
SLOT_HORIZON_DAYS=14
SLOT_DURATION_MINUTES=60

# ---- Storage (optional overrides) ----
# DB_PATH=/home/YOURUSER/dental_voice_agent/clinic.db
# AUDIO_DIR=/home/YOURUSER/dental_voice_agent/audio

# ---- Local dev ----
PORT=8000
